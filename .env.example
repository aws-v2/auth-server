# Example environment file for docker-compose
# Copy this file to .env and update with your values

# Mail Configuration
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Database Configuration (defaults work for docker-compose)
DEV_DATASOURCE_USERNAME=root
DEV_DATASOURCE_PASSWORD=root
DEV_DATASOURCE_URL=jdbc:postgresql://postgres:5432/auth_db_dev

# NATS Configuration
DEV_NATS_URL=nats://nats:4222
DEV_NATS_USERNAME=auth-server
DEV_NATS_PASSWORD=auth-secret

# JWT Secret (generate a new one for production)
DEV_JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_SECRET_EXPIRATION=86400000

# Frontend URL
DEV_FRONTEND_URL=http://localhost:5173

# Redis Password (for rate limiting)
REDIS_PASSWORD=redis-password
